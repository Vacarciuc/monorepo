NODE_ENV=development

HOST=0.0.0.0
PORT=3000

# Database (container name + port)
DB_HOST=seller-db
DB_PORT=5432
DB_USER=seller
DB_PASSWORD=seller
DB_NAME=seller

# RabbitMQ (container name + port)
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=user
RABBITMQ_PASSWORD=pass

# RabbitMQ topology
RABBITMQ_EXCHANGE=order.exchange
RABBITMQ_QUEUE=seller.queue
RABBITMQ_CONSUMER_ROUTING_KEY=order.created.*
RABBITMQ_PRODUCER_ROUTING_KEY=order.processed
