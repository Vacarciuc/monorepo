NODE_ENV=development

HOST=0.0.0.0
PORT=3000

# Database (container name + port)
ORDER_SERVICE_DB_HOST=order-db
ORDER_SERVICE_DB_PORT=5432
ORDER_SERVICE_DB_USER=order
ORDER_SERVICE_DB_PASSWORD=order
ORDER_SERVICE_DB_NAME=order

# RabbitMQ (container name + port)
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=user
RABBITMQ_PASS=pass
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASS}@${RABBITMQ_HOST}:${RABBITMQ_PORT}
