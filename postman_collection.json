              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"seller@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"SELLER\"\n}"
            },
            "url": {
              "raw": "http://localhost:3001/auth/register",
