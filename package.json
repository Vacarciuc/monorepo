{
  "name": "monorepo",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "format": "cross-env-shell \"prettier --no-error-on-unmatched-pattern --write --cache ./apps/$DIR/**/*\"",
    "format:auth-service": "cross-env DIR=auth-service pnpm run format",
    "format:gateway": "cross-env DIR=gateway pnpm run format",
    "format:frontend": "cross-env DIR=frontend pnpm run format",
    "format:seller-service": "cross-env DIR=seller-service pnpm run format",
    "format:order-service": "cross-env DIR=order-service pnpm run format",
    "format:all": "pnpm format:auth-service; pnpm format:gateway; pnpm format:frontend; pnpm format:seller-service; pnpm format:order-service"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "prettier": "^3.8.1",
    "cross-env": "^10.1.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.3"
}
